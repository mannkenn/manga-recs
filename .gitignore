# ========================================
# Data & Artifacts
# ========================================
# Keep directory structure but ignore contents
data/raw/*.json
data/raw/*.csv
data/cleaned/*.parquet
data/features/*.parquet
data/features/*.pkl
data/models/*.pkl
data/models/*.joblib

# Keep empty directories
!data/raw/.gitkeep
!data/cleaned/.gitkeep
!data/features/.gitkeep
!data/models/.gitkeep

# ========================================
# ML/MLOps
# ========================================
mlflow.db
mlruns/
artifacts/*.pkl
artifacts/*.joblib
artifacts/models/
artifacts/features/

# Keep artifact directories
!artifacts/models/.gitkeep
!artifacts/features/.gitkeep

# ========================================
